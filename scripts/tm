#!/bin/bash

TMUXP_REPO="$HOME/dotfiles/tmuxp"
CACHE_DIR="/tmp/tm_cache"
mkdir -p "$CACHE_DIR"

# Get cache file path for a config file
get_cache_file() {
	local file="$1"
	local hash=$(echo "$file" | md5sum | cut -d' ' -f1)
	echo "$CACHE_DIR/$hash"
}

# Extract session name from a config file
get_session_name() {
	yq .session_name "$1" 2>/dev/null
}

# Get cached session name if file hasn't changed
get_session_name_cached() {
	local file="$1"
	local cache_file=$(get_cache_file "$file")
	local current_mtime=$(stat -c %Y "$file" 2>/dev/null)

	if [ -f "$cache_file" ]; then
		local cached_mtime=$(cut -d'|' -f2 "$cache_file" 2>/dev/null)
		if [ "$current_mtime" = "$cached_mtime" ]; then
			# Cache hit: file hasn't changed
			cut -d'|' -f1 "$cache_file"
			return 0
		fi
	fi

	# Cache miss: reparse and store
	local session=$(get_session_name "$file")
	if [ -n "$session" ]; then
		echo "$session|$current_mtime" > "$cache_file"
		echo "$session"
	fi
}

# Format session output (without checking if active - lazy evaluation)
format_session_line() {
	local file="$1"
	local session=$(get_session_name_cached "$file")

	if [ -z "$session" ]; then
		return 1
	fi

	# Output: session_name<tab>file_path
	printf "%s\t%s\n" "$session" "$file"
}

# Export functions for xargs subshells
export -f get_cache_file get_session_name get_session_name_cached format_session_line
export CACHE_DIR

# Find all config files and format them (in parallel, with mtime caching)
find_sessions() {
	find "$TMUXP_REPO" -type f \( -name '*.yaml' -o -name '*.yml' \) | xargs -P 8 -I {} bash -c 'format_session_line "$@"' _ {}
}

# Main: select a session and load it
selected=$(find_sessions | fzf --delimiter=$'\t' --with-nth=1 \
	--preview 'session_name=$(echo {1} | sed "s/ \*//"); \
	if tmux has-session -t "$session_name" 2>/dev/null; then echo "[ACTIVE]"; fi; \
	([ -x "$(command -v bat)" ] && bat --color=always {2} || batcat --color=always {2})')
file_path=$(echo "$selected" | cut -f2)
tmuxp load -y "$file_path"

