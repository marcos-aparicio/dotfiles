#!/bin/bash

TMUXP_REPO="$HOME/dotfiles/tmuxp"

# Extract session name from a config file
get_session_name() {
	yq .session_name "$1" 2>/dev/null
}

# Format session output (without checking if active - lazy evaluation)
format_session_line() {
	local file="$1"
	local session=$(get_session_name "$file")

	if [ -z "$session" ]; then
		return 1
	fi

	# Output: session_name<tab>file_path
	printf "%s\t%s\n" "$session" "$file"
}

# Check if a session is active and format with marker
format_with_marker() {
	local session="$1"
	local marker=""
	if tmux has-session -t "$session" 2>/dev/null; then
		marker=" *"
	fi
	echo "$session$marker"
}

# Export functions for xargs subshells
export -f get_session_name format_session_line format_with_marker

# Find all config files and format them (in parallel, no session checks)
find_sessions() {
	find "$TMUXP_REPO" -type f \( -name '*.yaml' -o -name '*.yml' \) | xargs -P 8 -I {} bash -c 'format_session_line "$@"' _ {}
}

# Main: select a session and load it
selected=$(find_sessions | fzf --delimiter=$'\t' --with-nth=1 \
	--preview 'session_name=$(echo {1} | sed "s/ \*//"); \
	if tmux has-session -t "$session_name" 2>/dev/null; then echo "[ACTIVE]"; fi; \
	([ -x "$(command -v bat)" ] && bat --color=always {2} || batcat --color=always {2})')
file_path=$(echo "$selected" | cut -f2)
tmuxp load -y "$file_path"

