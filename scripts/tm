#!/bin/bash

TMUXP_REPO="$HOME/dotfiles/tmuxp"

# Extract session name from a config file
get_session_name() {
	yq .session_name "$1" 2>/dev/null
}

# Check if a session is active using pre-fetched list (much faster than has-session)
is_session_active() {
	local session="$1"
	local active_sessions="$2"
	echo "$active_sessions" | grep -Fxq "$session"
}

# Format session output with indicator if active
format_session_line() {
	local file="$1"
	local active_sessions="$2"
	local session=$(get_session_name "$file")

	if [ -z "$session" ]; then
		return 1
	fi

	local marker=""
	if is_session_active "$session" "$active_sessions"; then
		marker=" *"
	fi

	# Output: display_name<tab>file_path<tab>session_name
	printf "%s\t%s\t%s\n" "$session$marker" "$file" "$session"
}

# Export functions for xargs subshells
export -f get_session_name is_session_active format_session_line

# Find all config files and format them (in parallel)
find_sessions() {
	local active_sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null)
	export active_sessions
	find "$TMUXP_REPO" -type f \( -name '*.yaml' -o -name '*.yml' \) | xargs -P 8 -I {} bash -c 'format_session_line "$@"' _ {} "$active_sessions"
}

# Main: select a session and load it
selected=$(find_sessions | fzf --delimiter=$'\t' --with-nth=1 --preview '([ -x "$(command -v bat)" ] && bat --color=always {2} || batcat --color=always {2})')
file_path=$(echo "$selected" | cut -f2)
tmuxp load -y "$file_path"

