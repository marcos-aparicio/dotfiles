#!/bin/bash

THYME_STATUS="${HOME}/.thyme-tmux"

if [ ! -f "$THYME_STATUS" ]; then
    exit 1
fi

# Check if paused (not modified in last second)
last_modified=$(stat -c %Y "$THYME_STATUS" 2>/dev/null)
current_time=$(date +%s)
time_since_update=$((current_time - last_modified))

if [ $time_since_update -gt 1 ]; then
    # Paused - change color to yellow
    output=$(cat "$THYME_STATUS" | sed 's/#\[fg=default\]/#[fg=yellow]/g')

    # Extract minutes and seconds from the output
    minutes=$(echo "$output" | grep -oE '[0-9]{1,2}:[0-9]{2}' | cut -d: -f1)
    seconds=$(echo "$output" | grep -oE '[0-9]{1,2}:[0-9]{2}' | cut -d: -f2)

    # Only show seconds if minutes is 00
    if [[ "$minutes" =~ ^(00|0)$ ]] ; then
        time_display="${seconds}s"
    else
        time_display="${minutes}m"
    fi

    echo "󰍷 $time_display "
else
    # Running - keep default color
    output=$(cat "$THYME_STATUS")

    # Extract minutes and seconds from the output
    minutes=$(echo "$output" | grep -oE '[0-9]{1,2}:[0-9]{2}' | cut -d: -f1)
    seconds=$(echo "$output" | grep -oE '[0-9]{1,2}:[0-9]{2}' | cut -d: -f2)

    # Only show seconds if minutes is 00
    if [[ "$minutes" =~ ^(00|0)$ ]] ; then
        time_display="${seconds}s"
    else
        time_display="${minutes}m"
    fi

    echo " $time_display "
fi
