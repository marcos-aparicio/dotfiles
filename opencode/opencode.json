{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "ask"
  },
  "mcp": {
    "anki-mcp": {
      "type": "local",
      "command": [
        "ankimcp",
        "--stdio"
      ],
      "environment": {
        "ANKI_CONNECT_URL": "http://localhost:8765"
      },
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/chromium",
        "--headless"
      ]
    },
    "calendar": {
      "type": "local",
      "command": [
        "npx",
        "caldav-mcp"
      ],
      "environment": {
        "CALDAV_BASE_URL": "{env:CALDAV_BASE_URL}",
        "CALDAV_USERNAME": "{env:CALDAV_USERNAME}",
        "CALDAV_PASSWORD": "{env:CALDAV_PASSWORD}"
      }
    }
  },
  "plugin": [
    "/home/marcos/.local/share/npm-global/lib/node_modules/@rynfar/meridian/plugin/meridian.ts"
  ]
}
