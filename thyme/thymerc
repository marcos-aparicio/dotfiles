timer: 1500               # seconds per pomodoro
timer_break: 300          # seconds per break
timer_warning: 300        # seconds left to show warning
repeat: 4                 # default times to repeat
color_default: "default"  # color for pomodoros
status_override: false
color_warning: "red"      # color for pomodoros warnings
color_warning: "yellow"
color_break: "bright blue"
hooks:
  notify:
    events: ["after"]
    command: "notify-send \"Pomodoro done #{repeat_suffix}\" -title \"thyme\" && paplay $(print -rC1 -- ${(s[:])^XDG_DATA_DIRS}/sounds/freedesktop/stereo/interval-end.oga(ND))"

  notify_break:
    events: ["after_break"]
    command: "notify-send \"Break done #{repeat_suffix}\" -title \"thyme\" && paplay $(print -rC1 -- ${(s[:])^XDG_DATA_DIRS}/sounds/freedesktop/stereo/interval-end.oga(ND))"

  echo_after_all:
    events: ["after_all"]
    command: "echo \"You're all done, congrats!\""
